{
    "version": 2,
    "builds": [
        {
            "src": "config/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "config/wsgi.py"
        }
    ],
    "functions": {
        "config/wsgi.py": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron/notificar-padres/?key=default-cron-secret-2026",
            "schedule": "0 12 * * 1-5"
        }
    ]
}
